{
  "name": "media-compressor",
  "version": "0.1.0",
  "private": true,
  "description": "A local image and video conversion/compression desktop app.",
  "type": "module",
  "main": "electron/main.js",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "prototype": "python3 -m http.server 5173 -d src",
    "dev": "vite --host 127.0.0.1",
    "desktop": "electron .",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "verify:media": "node scripts/verify-media.mjs",
    "prepare:ffmpeg": "node scripts/prepare-ffmpeg.mjs",
    "generate:icon": "node scripts/generate-app-icon.mjs",
    "dist:mac": "pnpm run build && pnpm run generate:icon && pnpm run prepare:ffmpeg && electron-builder --mac dmg dir"
  },
  "build": {
    "appId": "com.rennnn.media-compressor",
    "productName": "可爱鸭",
    "directories": {
      "output": "release"
    },
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*",
      "!**/*.map",
      "!**/*.md",
      "!**/test{,s}/**/*",
      "!**/__test__/**/*",
      "!**/__tests__/**/*",
      "!**/docs/**/*",
      "!**/example{,s}/**/*"
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/ffmpeg",
        "to": "ffmpeg"
      }
    ],
    "mac": {
      "icon": "resources/icons/app-icon.png",
      "target": [
        "dmg",
        "dir"
      ],
      "category": "public.app-category.utilities",
      "electronLanguages": [
        "en",
        "zh_CN"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "contents": [
        {
          "x": 150,
          "y": 180,
          "type": "file"
        },
        {
          "x": 420,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@img/colour": "1.1.0",
    "detect-libc": "2.1.2",
    "react": "latest",
    "react-dom": "latest",
    "scheduler": "0.27.0",
    "semver": "7.8.5",
    "sharp": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "electron": "latest",
    "electron-builder": "^26.8.1",
    "typescript": "latest",
    "vite": "latest"
  },
  "optionalDependencies": {
    "@img/sharp-darwin-arm64": "0.35.3",
    "@img/sharp-libvips-darwin-arm64": "1.3.2"
  }
}
